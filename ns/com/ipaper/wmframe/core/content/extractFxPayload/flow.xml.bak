<?xml version="1.0" encoding="UTF-8"?>

<FLOW VERSION="3.0" CLEANUP="true">
  <COMMENT> extractPayload - extract an inline payload from the supplied &#39;envelope&#39; string and return the payload and several fields from the envelope </COMMENT>

  <!-- nodes -->

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT></COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT> extractFxPayload - extract the payload from the supplied FX envelope string and return it along with several fields from the envelope </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT></COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT>   payloads from Liaison take on a number of forms, which is why this service is necessary - this service analyzes the envelope and extracts the payload as </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT>   a string and returns it to the caller - and even though this service returns the individual values of the fxEnvelope (along with the payload), in general, </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT>   you shouldn&#39;t have any interest in these fields, since they should not be used directly in mappings - only the payload should be used </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT></COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT>   Note that this service supports the handling of Base64 encoded Opaque payloads of the form: </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT></COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT>    &lt;body&gt;</COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT>         &lt;Opaque&gt;</COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT>                  &lt;DataType&gt;PO&lt;/DataType&gt;</COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT>                  &lt;DataStream&gt;PHNvYXBlbnY...&lt;/DataStream&gt;</COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT>         &lt;/Opaque&gt;</COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT>    &lt;/body&gt;</COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT></COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT>   in these situations, only the DataStream is returned as the actual payload </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT></COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT>   If you make any changes to this logic, please test with the complete set of FX envelopes from Liaison, found in the frameworktestdocs/fxenvs folder </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT></COMMENT>
</SEQUENCE>

<MAP TIMEOUT="" MODE="STANDALONE">
