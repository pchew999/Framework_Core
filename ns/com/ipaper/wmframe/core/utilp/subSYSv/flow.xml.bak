<MAP TIMEOUT="" MODE="STANDALONE">
  <COMMENT></COMMENT>
</MAP>

<BRANCH TIMEOUT="" SWITCH="/sFwTransactionid">
  <COMMENT> if the caller supplied a transaction id, do $FOLDER$ and $FNAME$ substitution using the active knowns of the treansaction </COMMENT>

  <!-- nodes -->

<SEQUENCE NAME="$null" TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT> if not, do nothing </COMMENT>

  <!-- nodes -->

<MAP TIMEOUT="" MODE="STANDALONE">
  <COMMENT> nothing </COMMENT>
</MAP>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT> if so, do the substitution and log it </COMMENT>

  <!-- nodes -->

<INVOKE TIMEOUT="" SERVICE="com.ipaper.wmframe.core.data.trans:getActiveKnowns" VALIDATE-IN="$none" VALIDATE-OUT="$none">
  <COMMENT> sKnownFolder sKnownFilename </COMMENT>

