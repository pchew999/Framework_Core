  <COMMENT></COMMENT>

  <!-- nodes -->

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT></COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT> subTVK - substitute transaction variables and knowns in a supplied string </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT></COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT>   modified to support excluding substitution on * = known filename </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT></COMMENT>
</SEQUENCE>

<MAP TIMEOUT="" MODE="STANDALONE">
  <COMMENT></COMMENT>
</MAP>

<BRANCH TIMEOUT="" LABELEXPRESSIONS="true">
  <COMMENT></COMMENT>

  <!-- nodes -->

<SEQUENCE NAME="includeKnowns == $null || includeKnowns == &#39;true&#39;" TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT></COMMENT>

  <!-- nodes -->

<INVOKE TIMEOUT="" SERVICE="com.ipaper.wmframe.core.data.trans:getActiveKnowns" VALIDATE-IN="$none" VALIDATE-OUT="$none">
