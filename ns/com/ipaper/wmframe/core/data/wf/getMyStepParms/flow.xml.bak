<?xml version="1.0" encoding="UTF-8"?>

<FLOW VERSION="3.0" CLEANUP="true">
  <COMMENT> fwGetCurrentWorkflowStepActionParms - get the workflow&#39;s current step action and parameters </COMMENT>

  <!-- nodes -->

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT></COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT> getMyStepParms - get the workflow&#39;s current step parameters - both component and rfts parms </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT>    the output of this service are all of the strings/values of the step&#39;s component parms, which will vary by component </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT></COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT> note that even though this service allows you to specify the step number, this should ONLY be used as a debugging aid </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT>  1/17/25 - modified to support the new flow:log and z_getWorkflowByIID services, as well as dropping rfts support </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT></COMMENT>
</SEQUENCE>

<MAP TIMEOUT="" MODE="STANDALONE">
  <COMMENT></COMMENT>
</MAP>

<BRANCH TIMEOUT="" SWITCH="/sFwTracetransid">
  <COMMENT> if a transaction id is supplied, then parameters are from the compiled workflow in the transaction - otherwise from the original workflow in step 1 </COMMENT>

  <!-- nodes -->

<SEQUENCE NAME="/^[D|T|P][0-9|C]*[0-9]$/" TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT></COMMENT>

  <!-- nodes -->

<MAP TIMEOUT="" MODE="STANDALONE">
  <COMMENT></COMMENT>
</MAP>

<MAP TIMEOUT="" MODE="STANDALONE">
  <COMMENT> SELECT TO_CHAR(WORKFLOW_STEPS) AS WORKFLOW_STEPS,CURRENT_WORKFLOW_STEP FROM TFW_TRANS_ACTIVE WHERE TRANSACTION_ID=&#39;%sFwTransactionid%&#39; </COMMENT>
