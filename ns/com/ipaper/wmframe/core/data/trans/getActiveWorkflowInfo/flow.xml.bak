<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT> getActiveWorkflowInfo - get the currently active workflow name for this transaction, as well as the retention values </COMMENT>
</SEQUENCE>

<MAP TIMEOUT="" MODE="STANDALONE">
  <COMMENT> SELECT TO_CHAR(WORKFLOW_STEPS) FROM TFW_TRANS_ACTIVE WHERE TRANSACTION_ID=&#39;%sFwTransactionid%&#39; </COMMENT>
  <MAPTARGET>

<Values version="2.0">
  <record name="xml" javaclass="com.wm.util.Values">
    <value name="node_type">record</value>
