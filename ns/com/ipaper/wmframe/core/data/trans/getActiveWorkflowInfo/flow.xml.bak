<MAPSET NAME="Setter" OVERWRITE="true" VARIABLES="true" GLOBALVARIABLES="false" FIELD="/sSql;1;0">
  <DATA ENCODING="XMLValues" I18N="true">

<Values version="2.0">
  <value name="xml">SELECT dbms_lob.substr( WORKFLOW_STEPS, 4000,         1 ) AS WORKFLOW_STEPS1,
             dbms_lob.substr( WORKFLOW_STEPS, 4000,   4001 ) AS WORKFLOW_STEPS2,
             dbms_lob.substr( WORKFLOW_STEPS, 4000,   8001 ) AS WORKFLOW_STEPS3,
             dbms_lob.substr( WORKFLOW_STEPS, 4000, 12001 ) AS WORKFLOW_STEPS4,
             dbms_lob.substr( WORKFLOW_STEPS, 4000, 16001 ) AS WORKFLOW_STEPS5,
             dbms_lob.substr( WORKFLOW_STEPS, 4000, 20001 ) AS WORKFLOW_STEPS6,
             dbms_lob.substr( WORKFLOW_STEPS, 4000, 24001 ) AS WORKFLOW_STEPS7,
             dbms_lob.substr( WORKFLOW_STEPS, 4000, 28001 ) AS WORKFLOW_STEPS8,
             dbms_lob.substr( WORKFLOW_STEPS, 4000, 32001 ) AS WORKFLOW_STEPS9,
             dbms_lob.substr( WORKFLOW_STEPS, 4000, 36001 ) AS WORKFLOW_STEPS10,
             dbms_lob.substr( WORKFLOW_STEPS, 4000, 40001 ) AS WORKFLOW_STEPS11,
             dbms_lob.substr( WORKFLOW_STEPS, 4000, 44001 ) AS WORKFLOW_STEPS12,
             dbms_lob.substr( WORKFLOW_STEPS, 4000, 48001 ) AS WORKFLOW_STEPS13,
             dbms_lob.substr( WORKFLOW_STEPS, 4000, 52001 ) AS WORKFLOW_STEPS14,
             dbms_lob.substr( WORKFLOW_STEPS, 4000, 56001 ) AS WORKFLOW_STEPS15
  FROM TFW_TRANS_ACTIVE WHERE TRANSACTION_ID='%sFwTransactionid%'</value>
  <record name="type" javaclass="com.wm.util.Values">
    <value name="node_type">unknown</value>
    <value name="node_subtype">unknown</value>
    <value name="is_public">false</value>
    <value name="field_name">sSql</value>
    <value name="field_type">string</value>
    <value name="field_dim">0</value>
    <value name="nillable">true</value>
    <value name="form_qualified">false</value>
    <value name="is_global">false</value>
  </record>
</Values>
</DATA>
</MAPSET>
</MAP>

