<BRANCH TIMEOUT="" SWITCH="/workflowIID">
  <COMMENT></COMMENT>

  <!-- nodes -->

<SEQUENCE NAME="$null" TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT> if no workflow iid was supplied, see if the transaction was created with a workflow iid (saved in the WORKFLOW_NAME column) </COMMENT>

  <!-- nodes -->

<MAP TIMEOUT="" MODE="STANDALONE">
  <COMMENT></COMMENT>
</MAP>

<BRANCH TIMEOUT="" SWITCH="/wfName">
  <COMMENT> if the WORKFLOW_NAME column has a workflow iid in it, use that to start the transaction, avoiding discernment </COMMENT>

  <!-- nodes -->

<SEQUENCE NAME="/^W-/" TIMEOUT="" EXIT-ON="FAILURE">
