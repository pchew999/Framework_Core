<BRANCH TIMEOUT="" LABELEXPRESSIONS="true">
  <COMMENT> saveTimeout *= 1000 </COMMENT>

  <!-- nodes -->

<INVOKE NAME="saveTimeout != $null" TIMEOUT="" SERVICE="pub.math:multiplyInts" VALIDATE-IN="$none" VALIDATE-OUT="$none">
  <COMMENT> saveTimeout=saveTimeout*1000 (to put it in usecs) </COMMENT>

