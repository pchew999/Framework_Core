<Values version="2.0">
  <value name="xml">UPDATE TFW_ERROR_LOG
       SET USD_TICKET_NUMBER='%sdmTicketnumber%', USD_TICKET_HANDLE='%sdmTicketnumberHandle%'
 WHERE ERROR_NUM='%errorNumber%' AND ERROR_NUM_GUID='0'</value>
