<?xml version="1.0" encoding="UTF-8"?>

<FLOW VERSION="3.0" CLEANUP="true">
  <COMMENT></COMMENT>

  <!-- nodes -->

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT></COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT> registerErrorSN - register an error in the framework and create a ServiceNow ticket if necessary (duplicate tickets will be supressed) </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT></COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT> inputs: (required)  </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT> errorSource - discrete known identifier indicating the source of the error (ie, CSFW, SAP, APP1, etc)   informational only  </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT> errorNumber - a brief, consistent and predictable text value used to uniquely identify a given error message </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT> errorMessage - the full text of the error - can be multiline </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT></COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT> inputs: (optional)   </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT> errorMessageBrief - brief, one-line description of error - default: first 250 characters of errorMessage </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT> ticketPriority - 2 or 3 but not value-checked </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT> ticketQueue - ticket queue within SDM where the ticket is to be routed - default: ZWEB GENERATED (***DO NOT USE***) </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT> ticketArea - from among over 2300 in the SDM system - default: OTHER.OTHER.SOFTWARE </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT> closingSymptomCode - &#39;High CPU Usage&#39;, &#39;Slow Response&#39;, &#39;Unable to Connect&#39;, etc </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT> closingRootCauseCode - &#39;Bad Data&#39;, &#39;Code Defect&#39;, &#39;Human Error&#39;, etc   (default = zNot Identified ) </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT> closingResolutionCode - &#39;Code Fix&#39;, &#39;Data Change&#39;, &#39;Reset&#39;, etc  (default = zNot Identified) </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT> externalTicketNumber - free form text normally indicating the source ticketing system&#39;s unique identifier </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT></COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT> output: </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT> ticketNumber- the ticket number generated in SDM for this error </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT> message - status message of the ticket, either Normal successful completion, or FE0540-FE0544 error </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT></COMMENT>
</SEQUENCE>

<MAP TIMEOUT="" MODE="STANDALONE">
  <COMMENT></COMMENT>
</MAP>

<MAP TIMEOUT="" MODE="STANDALONE">
  <COMMENT>append SN to the errorNumber to accommodate two insert statements..SN and SDM</COMMENT>
  <MAPTARGET>

