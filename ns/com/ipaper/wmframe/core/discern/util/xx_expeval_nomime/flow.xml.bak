<BRANCH TIMEOUT="" LABELEXPRESSIONS="true">
  <COMMENT> check if we are dealing with a simple EDI expression or one with a &#39;where&#39; clause expression </COMMENT>

  <!-- nodes -->

<SEQUENCE NAME="%x1% > -1 &amp;&amp; %x2% > %x1%" TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT> the edi expression has a &#39;where&#39; clause   N201[N101=&#34;BT&#34;]</COMMENT>

  <!-- nodes -->

<MAP TIMEOUT="" MODE="STANDALONE">
  <COMMENT></COMMENT>
</MAP>

