<BRANCH TIMEOUT="" SWITCH="/firstChar">
  <COMMENT> based on the first character of the sTerm, generate an sFrag result </COMMENT>

  <!-- nodes -->

<SEQUENCE NAME="`" TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT> the term is a literal string so strip the leading and trailing &#39;s </COMMENT>

  <!-- nodes -->

<INVOKE TIMEOUT="" SERVICE="pub.string:replace" VALIDATE-IN="$none" VALIDATE-OUT="$none">
  <COMMENT> sFrag = replace(sTerm, &#34;`&#34;, &#34;&#34;)      remove leading and trailing ` backquotes </COMMENT>

