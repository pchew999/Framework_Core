<?xml version="1.0" encoding="UTF-8"?>

<FLOW VERSION="3.0" CLEANUP="true">
  <COMMENT> getAllInstanceConfiguration - get the configuration of all instances, whether they are broker or UM </COMMENT>

  <!-- nodes -->

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT></COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT> refreshAllInstanceGVs - get the configuration of all instances, whether they are broker or UM and refresh the global variables on this instance </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT></COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT>   This service creates/updates 5 global variables based on the current environment (DEV/TEST/PROD): </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT>         OBSOLETE fwBrokerClusterList - the list of broker clusters in this environment </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT>         OBSOLETE fwUMClusterList - the list of UM clusters in this environment </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT>         OBSOLETE fwDistClusterList - the list of distributed clusters in this environment </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT>         fwCentralClusterList - the list of central clusters in this environment </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT>         OBSOLETE fwXoverInstance - the crossover instance for this instance (Broker&lt;==&gt;UM)  OR the routeTo cluster if this is a distributed instance </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT>  It also refreshes the list of fwMapGroup* global variables based on the MAP_GROUP value of each cluster </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT></COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT>  Note: even though global variables are permanent, this service is still run every time the IS starts - this service can also be run on demand </COMMENT>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT></COMMENT>
</SEQUENCE>

