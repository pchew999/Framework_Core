<Values version="2.0">
  <value name="xml">fwEnvelope trigger settings are:
  isBrokerConfigured          = %isBrokerConfigured%
  typeDisplayValue            = %typeDisplayValue%
  queueCapacity               = %queueCapacity%
  queueRefillLevel            = %queueRefillLevel%
  maxExecutionThreadsThrottle = %maxExecutionThreadsThrottle%
  name                        = %name%
  service                     = %service%
  documentType                = %documentType%
  filterSource                = %filterSource%
  umFilter                    = %umFilter%
  documentTypesString         = %documentTypesString%
  retrievalState              = %retrievalState%
  processingState             = %processingState%</value>
  <record name="type" javaclass="com.wm.util.Values">
    <value name="node_type">record</value>
