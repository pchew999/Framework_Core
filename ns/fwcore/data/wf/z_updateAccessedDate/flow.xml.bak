  <DATA ENCODING="XMLValues" I18N="true">

<Values version="2.0">
  <value name="xml">UPDATE %tableName% SET 
  SYN_ACCESSED_DATE=to_char(SYS_EXTRACT_UTC(SYSTIMESTAMP),'YYYY-MM-DD HH24:MI:SS.FF TZR'),
  SYN_ACCESSED_BY= '%username%',
  SYN_ACCESSED_APP='%instanceSpec% %callingService%'
WHERE %sWhereClause%</value>
