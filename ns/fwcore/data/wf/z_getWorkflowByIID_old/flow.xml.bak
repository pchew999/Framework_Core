<MAPSET NAME="Setter" OVERWRITE="true" VARIABLES="true" GLOBALVARIABLES="false" FIELD="/sSql;1;0">
  <DATA ENCODING="XMLValues" I18N="true">

<Values version="2.0">
  <value name="xml">SELECT tfw_workflow.BUSINESS_IID, BUSINESS_NAME, PROJECT_NAME, tfw_workflow.WORKFLOW_IID, WORKFLOW_NAME,
      DEVELOPER, BRIEF_DESCRIPTION, tfw_workflow.LONG_DESCRIPTION, WF_TYPE, RUNTIME_KEY, TRACT, CI_NAME, DOC_FOLDER, SENDER_SPECIFICS, SENDER_APP_IID, RECEIVER_APP_IID, tfw_workflow.DOC_SUBTYPE, 
      SENDER_DOC_FORMAT, RECEIVER_DOC_FORMAT, SENDER_PROTOCOL, RECEIVER_PROTOCOL, SYNCHRONOUS, DUPCHECK,
      ATTR_SENDER_ALIAS, ATTR_RECEIVER_ALIAS, ATTR_DOCUMENT_ID, ATTR_MESSAGE_ID, ATTR_ORDER_NUM, ATTR_OTHER_NUM1, ATTR_OTHER_NUM2, ATTR_OTHER_NUM3, ATTR_OTHER_NUM4,
      LOG_RETENTION, CONTENT_RETENTION,
      tfw_workflow.ENABLED AS WFENABLED, SUSPEND_ON_ACCEPT, SUSPEND_AT_DELIVER, BULK_PROCESSING, REMEDIATION, 
      sapp.APP_NAME as SENDER_APP_NAME,
      rapp.APP_NAME as RECEIVER_APP_NAME,
	DOC_TYPE,
      TFW_WORKFLOW_STEPS.WORKFLOW_STEP_IID, WORKFLOW_STEP, TFW_WORKFLOW_STEPS.COMPONENT_IID, PACKAGE_NAME, SERVICE_NAME, COMPONENT_TYPE,
	tfw_workflow_step_env.ENVIRONMENT, tfw_workflow_step_env.CLUSTER_NAME, CONCURRENCY, tfw_workflow_step_env.ENABLED AS ENVENABLED, RETRY_COUNT, RETRY_INTERVAL,
	PARAMETER_NAME, PARAMETER_VALUE,
	SOURCE_ALIAS, SOURCE_FOLDER, SOURCE_FILENAME, SOURCE_ENCODING, SOURCE_SITE_PREGET, SOURCE_SITE_POSTGET, SOURCE_DELETE_AFTER_GET,
	TARGET_ALIAS, TARGET_FOLDER, TARGET_FILENAME, TARGET_ENCODING, TARGET_SITE_PREPUT, TARGET_SITE_POSTPUT, TARGET_ADD_TIMESTAMP, TARGET_TEMPFILENAME, TARGET_OVERWRITE, tfw_rafts_step.DESCRIPTION,
      ERROR_NUM,ERROR_TYPE,tfw_workflow.SYN_ACCESSED_DATE
FROM TFW_WORKFLOW
  LEFT JOIN tfw_app_picklist sapp ON tfw_workflow.SENDER_APP_IID=sapp.APP_IID
  LEFT JOIN tfw_app_picklist rapp ON tfw_workflow.RECEIVER_APP_IID=rapp.APP_IID
  LEFT JOIN tfw_docsubtype_picklist ON tfw_workflow.DOC_SUBTYPE=tfw_docsubtype_picklist.DOC_SUBTYPE
  LEFT JOIN tfw_business_picklist ON tfw_workflow.BUSINESS_IID = tfw_business_picklist.BUSINESS_IID
  LEFT JOIN tfw_workflow_steps    ON tfw_workflow.WORKFLOW_IID = tfw_workflow_steps.WORKFLOW_IID
  LEFT JOIN tfw_component         ON tfw_workflow_steps.COMPONENT_IID = tfw_component.COMPONENT_IID
  LEFT JOIN tfw_workflow_step_env ON tfw_workflow_steps.WORKFLOW_STEP_IID = tfw_workflow_step_env.WORKFLOW_STEP_IID
  LEFT JOIN tfw_component_parms   ON (tfw_workflow_step_env.WORKFLOW_STEP_IID = tfw_component_parms.WORKFLOW_STEP_IID AND tfw_workflow_step_env.ENVIRONMENT = tfw_component_parms.ENVIRONMENT)
  LEFT JOIN tfw_rafts_step        ON (tfw_workflow_step_env.WORKFLOW_STEP_IID = tfw_rafts_step.WORKFLOW_STEP_IID AND tfw_workflow_step_env.ENVIRONMENT = tfw_rafts_step.ENVIRONMENT)
  LEFT JOIN tfw_errors             ON tfw_workflow_steps.COMPONENT_IID = tfw_errors.COMPONENT_IID
WHERE tfw_workflow.WORKFLOW_IID='%sWorkflowIID%'  %envClause%
ORDER BY workflow_step,instr('DEV/TEST/PROD',ENVIRONMENT),parameter_name,ERROR_NUM
</value>
  <record name="type" javaclass="com.wm.util.Values">
    <value name="node_type">unknown</value>
    <value name="node_subtype">unknown</value>
    <value name="is_public">false</value>
    <value name="field_name">sSql</value>
    <value name="field_type">string</value>
    <value name="field_dim">0</value>
    <value name="nillable">true</value>
    <value name="form_qualified">false</value>
    <value name="is_global">false</value>
  </record>
</Values>
</DATA>
</MAPSET>
</MAP>

<INVOKE TIMEOUT="" SERVICE="com.ipaper.wmframe.core.data:dbDyn2LocalDB" VALIDATE-IN="$none" VALIDATE-OUT="$none">
