<LOOP TIMEOUT="" IN-ARRAY="/dbOutput/results">
  <COMMENT> loop over the FLAT records and turn them into a HEIRARCHICAL jsonDoc document </COMMENT>

  <!-- nodes -->

<MAP TIMEOUT="" MODE="STANDALONE">
  <COMMENT></COMMENT>
</MAP>

<BRANCH TIMEOUT="" LABELEXPRESSIONS="true">
  <COMMENT></COMMENT>

  <!-- nodes -->

<SEQUENCE NAME="%dbOutput/results/WORKFLOW_STEP% != %stepPrev%" TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT></COMMENT>

  <!-- nodes -->

<BRANCH TIMEOUT="" LABELEXPRESSIONS="true">
  <COMMENT></COMMENT>

  <!-- nodes -->

<INVOKE NAME="parmsPrev!=&#39;???&#39; &amp;&amp; parmsIndex!=&#39;-1&#39;" TIMEOUT="" SERVICE="pub.document:documentListToDocument" VALIDATE-IN="$none" VALIDATE-OUT="$none">
