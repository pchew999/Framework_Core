<MAPSET NAME="Setter" OVERWRITE="true" VARIABLES="true" GLOBALVARIABLES="false" FIELD="/sSql;1;0">
  <DATA ENCODING="XMLValues" I18N="true">

<Values version="2.0">
  <value name="xml">SELECT TP_ALIAS,tfw_tp_alias.ENVIRONMENT,CLUSTER_NAME,tfw_tp_alias.TP_IID,TP_NAME,ALIAS_TYPE,
   tfw_tp_alias.BUSINESS_IID,BUSINESS_NAME,tfw_tp_alias.APP_IID,APP_NAME,
   SUSPEND_ON_ACCEPT,SUSPEND_AT_DELIVER,CONCURRENCY,tfw_tp_alias.ENABLED as ENAALIAS,tfw_tradingpartner.ENABLED as ENAPARTNER,
	   SETTINGCODE,SETTING_TYPE,PINGHOST,SERVERHOST,SERVERPORT,USERID,PWD,TIMEOUT,ENCODING,TYPE_ACTPSVSEC,
	   FOLDER,FILENAME,TEMPFILENAME,ADD_TIMESTAMP,DELETE_AFTER_GET,ALLOW_REPLACE,
	   SITE_PRE,SITE_POST,URL,METHOD,CONTENT_TYPE,
	   EMAIL_TO,EMAIL_FROM,EMAIL_SUBJECT,DB_CONN,
          SAP_CONN_ALIAS,SAP_RCVPOR,SAP_RCVPRN,SAP_MANDT,
	   TOKEN_URL,
          AS2_SIGNATURE_ALGORITHM,AS2_INBOUND_ENCRYPTION,AS2_OUTBOUND_ENCRYPTION,AS2_INBOUND_BASE64_ENCODE,AS2_OUTBOUND_BASE64_ENCODE,AS2_MDN_RECEIPT_SIGNATURE,AS2_MDN_SYNCHRONOUS,AS2_MDN_ALTERNATE_URL,
		  AS2_CONTENT_DISPOSITION, AS2_DISP_NOTIF_OPTIONS, AS2_CERT_FILENAME, ENCODING,
   DLV_FROM_ORG, DLV_FROM_LOC, DLV_FROM_SYSTEM, DLV_TO_ORG, DLV_TO_LOC, DLV_TO_SYSTEM,
   DLV_VAR_PROTOCOL, AGFLD, APFLD,
   tfw_tp_alias.SYN_ACCESSED_DATE as ACCALIAS,tfw_tradingpartner.SYN_ACCESSED_DATE as ACCPARTNER,tfw_tp_settings.SYN_ACCESSED_DATE as ACCSETTINGS
FROM TFW_TP_ALIAS
   LEFT JOIN TFW_TRADINGPARTNER ON tfw_tp_alias.TP_IID=tfw_tradingpartner.TP_IID
   LEFT JOIN TFW_BUSINESS_PICKLIST ON tfw_tp_alias.BUSINESS_IID=tfw_business_picklist.BUSINESS_IID
   LEFT JOIN TFW_APP_PICKLIST ON tfw_tp_alias.APP_IID=tfw_app_picklist.APP_IID
   LEFT JOIN TFW_TP_SETTINGS ON TFW_TP_ALIAS.%settingsType%=TFW_TP_SETTINGS.SETTINGCODE
WHERE TP_ALIAS='%tpAlias%' AND TFW_TP_SETTINGS.SETTING_TYPE='%settingsType%'
ORDER BY TP_ALIAS,ENVIRONMENT DESC,CLUSTER_NAME DESC</value>
  <record name="type" javaclass="com.wm.util.Values">
    <value name="node_type">unknown</value>
    <value name="node_subtype">unknown</value>
    <value name="is_public">false</value>
    <value name="field_name">sSql</value>
    <value name="field_type">string</value>
    <value name="field_dim">0</value>
    <value name="nillable">true</value>
    <value name="form_qualified">false</value>
    <value name="is_global">false</value>
  </record>
</Values>
</DATA>
</MAPSET>
</MAP>
</BRANCH>

