<MAPSET NAME="Setter" OVERWRITE="true" VARIABLES="true" GLOBALVARIABLES="false" FIELD="/sMessage;1;0">
  <DATA ENCODING="XMLValues" I18N="true">

<Values version="2.0">
  <value name="xml">%sMessage%
 AS2=%settingCode% settings:
  PINGHOST='%docAliasSettings/ALIASSETTINGS/AS2/PINGHOST%'
  SERVERHOST='%docAliasSettings/ALIASSETTINGS/AS2/SERVERHOST%'
  SERVERPORT='%docAliasSettings/ALIASSETTINGS/AS2/SERVERPORT%'
  USERID='%docAliasSettings/ALIASSETTINGS/AS2/USERID%'
  PWD='*****'
  TIMEOUT='%docAliasSettings/ALIASSETTINGS/AS2/TIMEOUT%'
  URL='%docAliasSettings/ALIASSETTINGS/AS2/URL%'
  METHOD='%docAliasSettings/ALIASSETTINGS/AS2/METHOD%'
  CONTENT_TYPE='%docAliasSettings/ALIASSETTINGS/AS2/CONTENT_TYPE%'
  AS2_SIGNATURE_ALGORITHM='%docAliasSettings/ALIASSETTINGS/AS2/AS2_SIGNATURE_ALGORITHM%'
  AS2_INBOUND_ENCRYPTION='%docAliasSettings/ALIASSETTINGS/AS2/AS2_INBOUND_ENCRYPTION%'
  AS2_OUTBOUND_ENCRYPTION='%docAliasSettings/ALIASSETTINGS/AS2/AS2_OUTBOUND_ENCRYPTION%'
  AS2_INBOUND_BASE64_ENCODE='%docAliasSettings/ALIASSETTINGS/AS2/AS2_INBOUND_BASE64_ENCODE%'
  AS2_OUTBOUND_BASE64_ENCODE='%docAliasSettings/ALIASSETTINGS/AS2/AS2_OUTBOUND_BASE64_ENCODE%'
  AS2_MDN_RECEIPT_SIGNATURE='%docAliasSettings/ALIASSETTINGS/AS2/AS2_MDN_RECEIPT_SIGNATURE%'
  AS2_MDN_SYNCHRONOUS='%docAliasSettings/ALIASSETTINGS/AS2/AS2_MDN_SYNCHRONOUS%'
  AS2_MDN_ALTERNATE_URL='%docAliasSettings/ALIASSETTINGS/AS2/AS2_MDN_ALTERNATE_URL%'
  AS2_CONTENT_DISPOSITION='%docAliasSettings/ALIASSETTINGS/AS2/AS2_CONTENT_DISPOSITION%'
  AS2_DISP_NOTIF_OPTIONS='%docAliasSettings/ALIASSETTINGS/AS2/AS2_DISP_NOTIF_OPTIONS%'
  AS2_CERT_FILENAME= '%docAliasSettings/ALIASSETTINGS/AS2/AS2_CERT_FILENAME%'
  ENCODING= '%docAliasSettings/ALIASSETTINGS/AS2/ENCODING%'</value>
  <record name="type" javaclass="com.wm.util.Values">
    <value name="node_type">unknown</value>
    <value name="node_subtype">unknown</value>
    <value name="is_public">false</value>
