  <value name="xml">SELECT TP_ALIAS,ENVIRONMENT,CLUSTER_NAME,
    SUSPEND_ON_ACCEPT,SUSPEND_AT_DELIVER,CONCURRENCY,ENABLED
FROM TFW_TP_ALIAS
WHERE TP_IID='%tpIID%' AND APP_IID='%appIID%'
ORDER BY TP_ALIAS,ENVIRONMENT DESC,CLUSTER_NAME DESC</value>
