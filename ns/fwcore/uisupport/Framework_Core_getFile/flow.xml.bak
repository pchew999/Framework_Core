<BRANCH TIMEOUT="" LABELEXPRESSIONS="true">
  <COMMENT> depending on where the caller wants the file from... </COMMENT>

  <!-- nodes -->

<SEQUENCE NAME="environment==uienvironselection || clusterName == uienvironselection" TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT> get the file from the local server </COMMENT>

  <!-- nodes -->

<MAP TIMEOUT="" MODE="STANDALONE">
  <COMMENT></COMMENT>
</MAP>

<MAP TIMEOUT="" MODE="STANDALONE">
  <COMMENT> subFolder = substring(tid, 0, 6)      filereflen = length(fileref) </COMMENT>
