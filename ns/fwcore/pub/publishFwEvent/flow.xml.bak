<BRANCH TIMEOUT="" LABELEXPRESSIONS="true">
  <COMMENT> check that parameters are valid </COMMENT>

  <!-- nodes -->

<SEQUENCE NAME="eventOp != &#39;DOCARRIVED&#39; &amp;&amp; eventOp != &#39;DOCFAILED&#39; &amp;&amp; eventOp != &#39;DOCDELIVERED&#39;" TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT></COMMENT>

  <!-- nodes -->

<EXIT FROM="$flow" SIGNAL="FAILURE" FAILURE-MESSAGE="Cannot publish event without an eventOp">
  <COMMENT> Cannot publish event without an eventOp </COMMENT>
</EXIT>
</SEQUENCE>

<SEQUENCE NAME="evSenderAlias==&#39;&#39; || evSenderIID==&#39;&#39;" TIMEOUT="" EXIT-ON="FAILURE" DISABLED="true">
  <COMMENT></COMMENT>

  <!-- nodes -->

<EXIT FROM="$flow" SIGNAL="FAILURE" DISABLED="true" FAILURE-MESSAGE="Cannot publish event without sender info">
  <COMMENT> Cannot publish event without sender info </COMMENT>
</EXIT>
</SEQUENCE>

<SEQUENCE NAME="(eventOp==&#39;DOCDELIVERED&#39;) &amp;&amp; (evReceiverAlias==&#39;&#39; || evReceiverIID==&#39;&#39;)" TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT></COMMENT>

  <!-- nodes -->

<EXIT FROM="$flow" SIGNAL="FAILURE" FAILURE-MESSAGE="Cannot publish DOCDELIVERED event without receiver info">
  <COMMENT> Cannot publish DOCDELIVERED event without receiver info </COMMENT>
</EXIT>
</SEQUENCE>

<SEQUENCE NAME="evDocType==&#39;&#39; || evDocSubtype==&#39;&#39; || evWorkflowIID==&#39;&#39;" TIMEOUT="" EXIT-ON="FAILURE" DISABLED="true">
  <COMMENT></COMMENT>

  <!-- nodes -->

<EXIT FROM="$flow" SIGNAL="FAILURE" DISABLED="true" FAILURE-MESSAGE="Cannot publish event without workflow or document info">
  <COMMENT> Cannot publish event without workflow or document info </COMMENT>
</EXIT>
</SEQUENCE>
</BRANCH>

