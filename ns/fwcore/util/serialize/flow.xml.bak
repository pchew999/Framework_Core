<BRANCH TIMEOUT="" LABELEXPRESSIONS="true">
  <COMMENT> check if we are 5 minutes or more beyond the date the file was created, in case that thread failed for some reason </COMMENT>

  <!-- nodes -->

<SEQUENCE NAME="dateDifferenceSeconds > 300" TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT> if multiple threads hit this conditional at the same time, then they will no longer be serialized </COMMENT>

