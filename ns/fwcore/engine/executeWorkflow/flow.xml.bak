<BRANCH TIMEOUT="" LABELEXPRESSIONS="true">
  <COMMENT> if we are on the correct cluster, invoke the service, otherwise, re-route </COMMENT>

  <!-- nodes -->

<SEQUENCE NAME="clusterName == %fw/stepCluster% || posInMapGroup != -1" TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT> we are on the correct cluster, so just execute the service </COMMENT>

